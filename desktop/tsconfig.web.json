{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "outDir": "./dist-renderer",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["electron-vite/client"]
  },
  "include": ["src/**/*"]
}
